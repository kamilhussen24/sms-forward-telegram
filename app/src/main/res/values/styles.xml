<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ToggleButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/toggle_text_color</item>
        <item name="backgroundTint">@color/toggle_bg_color</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:gravity">center</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

</resources>
